# ============================================================
# DDI - Data Driven Intelligence | Backend Configuration
# ============================================================
# Copy this file to .env and fill in your API keys

# ----------------------------------------------------------
# REQUIRED: Anthropic Claude API (powers AI fact-checking)
# Get key at: https://console.anthropic.com
# ----------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ----------------------------------------------------------
# OPTIONAL NEWS SOURCE API KEYS
# The app works without these (uses GDELT + Google News RSS)
# Add more keys = more sources = better fact-checks
# ----------------------------------------------------------

# NewsAPI (https://newsapi.org) - Global/USA coverage
# Free: 100 req/day, covers 80,000+ sources
NEWSAPI_KEY=

# The Guardian (https://open-platform.theguardian.com) - UK/Europe
# Free: 12 req/sec, 5000 req/day
GUARDIAN_API_KEY=

# New York Times (https://developer.nytimes.com) - USA
# Free: 4000 req/day, 10 req/min
NYT_API_KEY=

# GNews (https://gnews.io) - Global (strong Asia coverage)
# Free: 100 req/day
GNEWS_API_KEY=

# Currents API (https://currentsapi.services) - Global
# Free: 600 req/day
CURRENTS_API_KEY=

# Mediastack (https://mediastack.com) - Global
# Free: 500 req/month
MEDIASTACK_API_KEY=

# Bing News Search (Azure Cognitive Services) - Global
# Free: 1000 transactions/month
BING_NEWS_API_KEY=

# ----------------------------------------------------------
# SMTP (Gmail) - For sending OTP verification emails
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to App Passwords → Create one for "Mail"
# 3. Paste the 16-char password below
# ----------------------------------------------------------
SMTP_EMAIL=
SMTP_APP_PASSWORD=

# ----------------------------------------------------------
# MongoDB - User data, fact-checks, activity logs
# ----------------------------------------------------------
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=MyApp
MONGO_DB=ddi
